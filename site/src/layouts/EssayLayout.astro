---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/essay/TableOfContents.svelte';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <TableOfContents client:idle />
  <main class="essay">
    <header class="essay-header prose">
      <h1>{title}</h1>
    </header>
    <article>
      <slot />
    </article>
  </main>
</BaseLayout>

<style>
  .essay {
    min-height: 100vh;
    padding-block: var(--space-2xl);
  }

  .essay-header {
    margin-bottom: var(--space-3xl);
  }

  .essay-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    line-height: 1.2;
  }
</style>
