---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BitGridBytes from '../../components/widgets/BitGridBytes.svelte';
---

<BaseLayout title="Sandbox: Bit Grid Bytes">
  <main style="padding: var(--space-2xl); max-width: var(--figure-width); margin-inline: auto;">
    <a href="/sandbox" style="color: var(--color-accent);">&larr; All widgets</a>
    <h1 style="margin-block: var(--space-lg); font-size: 1.75rem;">Bit Grid: Bytes</h1>
    <p style="color: var(--color-text-muted); margin-bottom: var(--space-xl);">
      Bits flip 8 at a time to foreshadow bytes and byte-addressable RAM.
      A CPU block sends signals along bus wires before each byte write.
    </p>
    <div style="background: var(--color-bg-raised); padding: var(--space-xl); border-radius: var(--radius-lg); border: 1px solid var(--color-border); overflow-x: auto;">
      <BitGridBytes client:load />
    </div>
  </main>
</BaseLayout>
