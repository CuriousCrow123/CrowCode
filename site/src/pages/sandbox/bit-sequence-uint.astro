---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BitSequenceUint from '../../components/widgets/BitSequenceUint.svelte';
---

<BaseLayout title="Sandbox: Bit Sequence Uint">
  <main style="padding: var(--space-2xl); max-width: var(--figure-width); margin-inline: auto;">
    <a href="/sandbox" style="color: var(--color-accent);">&larr; All widgets</a>
    <h1 style="margin-block: var(--space-lg); font-size: 1.75rem;">Bit Sequence: Unsigned Integer</h1>
    <p style="color: var(--color-text-muted); margin-bottom: var(--space-xl);">
      A row of interactive bits that encodes an unsigned decimal number.
      Click bits to flip them, click the value to type a number, or drag the value to scrub.
    </p>
    <div style="background: var(--color-bg-raised); padding: var(--space-xl); border-radius: var(--radius-lg); border: 1px solid var(--color-border);">
      <BitSequenceUint client:load />
    </div>
  </main>
</BaseLayout>
