{
	"name": "crowcode",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"postinstall": "cp node_modules/web-tree-sitter/web-tree-sitter.wasm static/tree-sitter.wasm && cp node_modules/tree-sitter-c/tree-sitter-c.wasm static/tree-sitter-c.wasm"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.5.0",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.1"
	},
	"dependencies": {
		"@codemirror/lang-cpp": "^6.0.3",
		"@codemirror/state": "^6.6.0",
		"@codemirror/theme-one-dark": "^6.1.3",
		"@codemirror/view": "^6.40.0",
		"codemirror": "^6.0.2",
		"tree-sitter-c": "^0.24.1",
		"web-tree-sitter": "^0.26.7"
	}
}
